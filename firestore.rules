rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function for the hardcoded superadmin
    function isSuperAdmin() {
      return request.auth != null && (request.auth.token.email == "rohit.official36@gmail.com" || request.auth.token.email == "rohit.no18@gmail.com");
    }

    // App Configuration & Toggles
    match /app_config/{docId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // User Lookup (uniqueness enforcement by email/phone)
    match /user_lookup/{key} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isSuperAdmin();
    }

    // Audit Logs (Telemetry Engine)
    match /audit_logs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSuperAdmin(); // Logs are immutable to the user
    }

    // Users collection and sub-collections
    match /users/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isSuperAdmin();
      match /{allPaths=**} {
        allow read, write: if (request.auth != null && request.auth.uid == userId) || isSuperAdmin();
      }
    }

    // Patients
    match /patients/{patientId} {
      allow read, update, delete: if (request.auth != null && resource.data.userId == request.auth.uid) || isSuperAdmin();
      allow create: if (request.auth != null && request.resource.data.userId == request.auth.uid) || isSuperAdmin();
    }

    // Documents
    match /documents/{docId} {
      allow read, update, delete: if (request.auth != null && resource.data.userId == request.auth.uid) || isSuperAdmin();
      allow create: if (request.auth != null && request.resource.data.userId == request.auth.uid) || isSuperAdmin();
    }

    // Appointments
    match /appointments/{apptId} {
      allow read, update, delete: if (request.auth != null && resource.data.userId == request.auth.uid) || isSuperAdmin();
      allow create: if (request.auth != null && request.resource.data.userId == request.auth.uid) || isSuperAdmin();
    }

    // Life Events
    match /life_events/{eventId} {
      allow read, update, delete: if (request.auth != null && resource.data.userId == request.auth.uid) || isSuperAdmin();
      allow create: if (request.auth != null && request.resource.data.userId == request.auth.uid) || isSuperAdmin();
    }

    // Doctors — only admins can write, patients can read their assigned doctor
    match /doctors/{doctorId} {
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    // Vitals
    match /vitals/{vitalId} {
      allow read, update, delete: if (request.auth != null && resource.data.userId == request.auth.uid) || isSuperAdmin();
      allow create: if (request.auth != null && request.resource.data.userId == request.auth.uid) || isSuperAdmin();
    }

    // Emergency Info — only writable by owner/admin, read via secure Cloud Function
    match /emergency_info/{patientId} {
      allow read: if isSuperAdmin();
      allow update, delete: if (request.auth != null && resource.data.userId == request.auth.uid) || isSuperAdmin();
      allow create: if (request.auth != null && request.resource.data.userId == request.auth.uid) || isSuperAdmin();
    }

    // Debug Logs — authenticated writes only, read by superadmin
    match /debug_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if isSuperAdmin();
    }
  }
}
