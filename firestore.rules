rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function for the hardcoded superadmin
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == "rohit.official36@gmail.com";
    }

    // App Configuration & Toggles
    match /app_config/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Users collection and sub-collections
    match /users/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isSuperAdmin();
      match /{allPaths=**} {
        allow read, write: if (request.auth != null && request.auth.uid == userId) || isSuperAdmin();
      }
    }

    // Patients
    match /patients/{patientId} {
      allow read, update, delete: if (request.auth != null && resource.data.userId == request.auth.uid) || isSuperAdmin();
      allow create: if (request.auth != null && request.resource.data.userId == request.auth.uid) || isSuperAdmin();
    }

    // Documents
    match /documents/{docId} {
      allow read, update, delete: if (request.auth != null && resource.data.userId == request.auth.uid) || isSuperAdmin();
      allow create: if (request.auth != null && request.resource.data.userId == request.auth.uid) || isSuperAdmin();
    }

    // Appointments
    match /appointments/{apptId} {
      allow read, update, delete: if (request.auth != null && resource.data.userId == request.auth.uid) || isSuperAdmin();
      allow create: if (request.auth != null && request.resource.data.userId == request.auth.uid) || isSuperAdmin();
    }

    // Life Events
    match /life_events/{eventId} {
      allow read, update, delete: if (request.auth != null && resource.data.userId == request.auth.uid) || isSuperAdmin();
      allow create: if (request.auth != null && request.resource.data.userId == request.auth.uid) || isSuperAdmin();
    }

    // Doctors
    match /doctors/{doctorId} {
      allow read: if request.auth != null;
      allow write: if (request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') || isSuperAdmin();
    }

    // Vitals
    match /vitals/{vitalId} {
      allow read, update, delete: if (request.auth != null && resource.data.userId == request.auth.uid) || isSuperAdmin();
      allow create: if (request.auth != null && request.resource.data.userId == request.auth.uid) || isSuperAdmin();
    }

    // Emergency Info
    match /emergency_info/{patientId} {
      allow read: if true;
      allow update, delete: if (request.auth != null && resource.data.userId == request.auth.uid) || isSuperAdmin();
      allow create: if (request.auth != null && request.resource.data.userId == request.auth.uid) || isSuperAdmin();
    }
  }
}
