{
    "hosting": {
        "public": "dist",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            { "source": "/login", "destination": "/index.html" },
            { "source": "/register", "destination": "/index.html" },
            { "source": "/dashboard", "destination": "/index.html" },
            { "source": "/profile", "destination": "/index.html" },
            { "source": "/patients", "destination": "/index.html" },
            { "source": "/documents", "destination": "/index.html" },
            { "source": "/vitals", "destination": "/index.html" },
            { "source": "/ai-chat", "destination": "/index.html" },
            { "source": "/ai-chat/*", "destination": "/index.html" },
            { "source": "/timeline", "destination": "/index.html" },
            { "source": "/notifications", "destination": "/index.html" },
            { "source": "/emergency", "destination": "/index.html" },
            { "source": "/admin", "destination": "/index.html" },
            { "source": "/admin/*", "destination": "/index.html" },
            { "source": "/privacy", "destination": "/index.html" },
            { "source": "/terms", "destination": "/index.html" },
            { "source": "/pulse/*", "destination": "/index.html" }
        ],
        "headers": [
            {
                "source": "**/*.@(eot|otf|ttf|ttc|woff|font.css)",
                "headers": [
                    {
                        "key": "Access-Control-Allow-Origin",
                        "value": "*"
                    }
                ]
            },
            {
                "source": "**/*.@(jpg|jpeg|gif|png|svg|webp)",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "max-age=31536000"
                    }
                ]
            },
            {
                "source": "**/*.@(js|css)",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "no-cache, no-store, must-revalidate"
                    }
                ]
            },
            {
                "source": "/index.html",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "no-cache"
                    }
                ]
            },
            {
                "source": "/**/sw.js",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "no-cache, no-store, must-revalidate"
                    }
                ]
            },
            {
                "source": "/registerSW.js",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "no-cache, no-store, must-revalidate"
                    }
                ]
            }
        ]
    },
    "firestore": {
        "rules": "firestore.rules",
        "indexes": "firestore.indexes.json"
    },
    "storage": {
        "rules": "storage.rules"
    }
}